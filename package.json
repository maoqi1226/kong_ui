{
  "name": "kong_ui",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "esbuild": "^0.27.4",
    "nanoid": "^3.3.11",
    "pairwise": "^1.0.1",
    "picocolors": "^1.1.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "rollup": "^4.59.0",
    "source-map-js": "^1.2.1",
    "vite": "^8.0.0",
    "warn": "^1.0.1"
  },
  "devDependencies": {
    "@cypress/grep": "^4.1.0",
    "cypress": "^15.12.0",
    "cypress-terminal-report": "^7.3.3",
    "dotenv": "^17.3.1",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2",
    "rimraf": "^6.1.3"
  },
  "scripts": {
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "env:up": "bash ./scripts/setup.sh",
    "env:down": "bash ./scripts/teardown.sh",
    "clean:results": "rimraf results",
    "test:run": "cypress run --browser chrome --headless",
    "test:ui": "cypress run --browser chrome --headed",
    "test:run:smoke": "cypress run --env grepTags=\"@smoke\",grepFilterSpecs=true,grepOmitFiltered=true",
    "report:merge": "mochawesome-merge results/reports/*.json > results/report.json",
    "report:generate": "marge results/report.json --reportDir results/html-report --inline",
    "test:report": "npm run clean:results && (npm run test:run; npm run report:merge; npm run report:generate)",
    "env:test:report": "npm run env:up && npm run clean:results && (npm run test:run; npm run env:down; npm run report:merge; npm run report:generate)"
  },
  "keywords": [],
